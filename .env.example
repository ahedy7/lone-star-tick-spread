# Copy this file to `.env` and fill in your own values. NEVER commit `.env`.
#
# A free GBIF account is required to use the GBIF *download* API (the full,
# reproducible occurrence pull). Register at https://www.gbif.org/user/profile
# These three values are your GBIF website login credentials.

GBIF_USER=your_gbif_username
GBIF_PWD=your_gbif_password
# The email GBIF should send the download-ready notification to.
GBIF_EMAIL=you@example.com
